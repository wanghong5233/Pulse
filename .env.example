# =========================================================
# Pulse 本地开发环境变量模板(提交到仓库)
#
# 1) 复制本文件为 .env 后再填写敏感值
# 2) 敏感字段(API Key、邮箱密码、Webhook)请勿提交
# 3) 后端启动: ./scripts/start.sh backend  (或 make backend)
# =========================================================


# =========================================================
# [1] 基础运行时
# =========================================================
ENV=dev
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# 主进程日志等级(控制台默认 WARNING,文件默认 DEBUG)
PULSE_LOG_LEVEL=INFO

# ---------- 唯一的 Python 解释器事实源 ----------
# Pulse 运行时(start_backend.sh) + 所有 smoke/test 脚本都应使用这一个 venv.
# 工程上的"单一事实源"原则: 不再维护 .venv 符号链接, 不再混用系统 python3
# 或 Windows Anaconda. 想改装位置直接改这里, 不要在项目根再造 .venv.
#
# 保持这个 venv 与 pyproject.toml 一致: 改 pyproject.toml 后在 venv 内跑
#   pip install -e .[dev]
# 即可, 不要把依赖装到系统 python 里.
PULSE_VENV_DIR=/root/.venvs/pulse


# =========================================================
# [2] LLM 模型
# =========================================================
# 策略: OpenAI 优先(强 tool-use / 指令遵循 / structured output),
#       DashScope Qwen3-Max 作为国内/OpenAI 不可用时的同档次回退.
#
# 配置优先级(从高到低, 见 LLMRouter.candidate_models):
#   1. MODEL_ROUTE_<ROUTE>_PRIMARY / _FALLBACK  —— 路由级显式覆盖(最强)
#   2. DEFAULT_ROUTE_MODELS[route]              —— 代码的路由级意图
#   3. MODEL_PRIMARY / MODEL_FALLBACK           —— 全局兜底
#   4. DEFAULT_ROUTE_MODELS["default"]          —— 最终兜底
#
# ⚠️ 重要语义(2026-04 第二轮修正):
#   * MODEL_PRIMARY 是"没有路由特化默认时的全局兜底", **不会压住**路由级
#     代码默认(如 planning→gpt-4.1). 需要覆盖路由级行为请用
#     MODEL_ROUTE_<ROUTE>_PRIMARY.
#   * 想让 planning 用 gpt-4o-mini? → 写 MODEL_ROUTE_PLANNING_PRIMARY=gpt-4o-mini,
#     而不是改 MODEL_PRIMARY (后者不会生效在 planning 上).
OPENAI_API_KEY=
OPENAI_BASE_URL=

DASHSCOPE_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 全局默认 (被 route 级别覆盖) ──
# Brain 主力走 OpenAI gpt-4.1; gpt-5 也可但成本高, 按需自己切.
MODEL_PRIMARY=gpt-4.1
MODEL_FALLBACK=qwen3-max

# ── Brain / Agent 核心决策路由 ──
# planning = ReAct 多工具决策, 需要强 tool-use + 长上下文指令遵循
MODEL_ROUTE_PLANNING_PRIMARY=gpt-4.1
MODEL_ROUTE_PLANNING_FALLBACK=qwen3-max

# classification = 意图路由 / 短结构化分类, 便宜快即可
MODEL_ROUTE_CLASSIFICATION_PRIMARY=gpt-4o-mini
MODEL_ROUTE_CLASSIFICATION_FALLBACK=qwen-turbo

# generation = 自由文本生成(回复塑形 / 摘要 / 话术), 中档即可
MODEL_ROUTE_GENERATION_PRIMARY=gpt-4o-mini
MODEL_ROUTE_GENERATION_FALLBACK=qwen-plus

# cheap = 后台偏好提取 / 日志摘要等低优先级调用
MODEL_ROUTE_CHEAP_PRIMARY=gpt-4o-mini
MODEL_ROUTE_CHEAP_FALLBACK=qwen-turbo

# ── Job 业务域子路由 (历史细分, 保留但默认走 OpenAI) ──
MODEL_ROUTE_JD_ANALYSIS_PRIMARY=gpt-4o-mini
MODEL_ROUTE_JD_ANALYSIS_FALLBACK=qwen3-max
MODEL_ROUTE_GREET_DECISION_PRIMARY=gpt-4.1
MODEL_ROUTE_GREET_DECISION_FALLBACK=qwen3-max
MODEL_ROUTE_CHAT_CLASSIFY_PRIMARY=gpt-4o-mini
MODEL_ROUTE_CHAT_CLASSIFY_FALLBACK=qwen-turbo
MODEL_ROUTE_CHAT_PLAN_PRIMARY=gpt-4o-mini
MODEL_ROUTE_CHAT_PLAN_FALLBACK=qwen-plus
MODEL_ROUTE_CHAT_REPLY_PRIMARY=gpt-4o-mini
MODEL_ROUTE_CHAT_REPLY_FALLBACK=qwen-plus
MODEL_ROUTE_SOURCE_FIT_PRIMARY=gpt-4o-mini
MODEL_ROUTE_SOURCE_FIT_FALLBACK=qwen3-max
MODEL_ROUTE_EMAIL_CLASSIFY_PRIMARY=gpt-4o-mini
MODEL_ROUTE_EMAIL_CLASSIFY_FALLBACK=qwen-turbo
MODEL_ROUTE_MATERIAL_DRAFT_PRIMARY=gpt-4o-mini
MODEL_ROUTE_MATERIAL_DRAFT_FALLBACK=qwen3-max
MODEL_ROUTE_COMPANY_INTEL_PRIMARY=gpt-4o-mini
MODEL_ROUTE_COMPANY_INTEL_FALLBACK=qwen3-max
MODEL_ROUTE_INTERVIEW_PREP_PRIMARY=gpt-4.1
MODEL_ROUTE_INTERVIEW_PREP_FALLBACK=qwen3-max


# =========================================================
# [3] 数据存储
# =========================================================
DATABASE_URL=postgresql://postgres:pulse@localhost:15433/pulse
LANGGRAPH_CHECKPOINT_DATABASE_URL=postgresql://postgres:pulse@localhost:15433/pulse

# 记忆（Pulse 采用 agentic search，不使用向量数据库，
#  决策见 docs/Pulse-MemoryRuntime设计.md 附录 B）
PULSE_CORE_MEMORY_PATH=~/.pulse/core_memory.json


# =========================================================
# [4] Agent Runtime(内核)
# =========================================================
AGENT_RUNTIME_ENABLED=false
AGENT_RUNTIME_TICK_SECONDS=15
AGENT_RUNTIME_MAX_ERRORS=5

# 活跃时段(所有巡检任务在非活跃时段不执行)
GUARD_TIMEZONE=Asia/Shanghai
GUARD_ACTIVE_START_HOUR=9
GUARD_ACTIVE_END_HOUR=22
GUARD_WEEKEND_START_HOUR=10
GUARD_WEEKEND_END_HOUR=20


# =========================================================
# [5] Job 业务域策略 (由 pulse.modules.job.config.JobSettings 加载)
# =========================================================
# 默认 workspace_id,用于黑名单 / 偏好等 workspace-scoped 存储
PULSE_JOB_DEFAULT_WORKSPACE_ID=job.default

# 打招呼
PULSE_JOB_GREET_BATCH_SIZE=3
PULSE_JOB_GREET_MATCH_THRESHOLD=65
PULSE_JOB_GREET_DAILY_LIMIT=50
PULSE_JOB_GREET_DEFAULT_KEYWORD=AI Agent 实习
# 若为空,模块内部使用默认模板
PULSE_JOB_GREET_GREETING_TEMPLATE=

# 对话
PULSE_JOB_CHAT_DEFAULT_PROFILE_ID=default
PULSE_JOB_CHAT_AUTO_EXECUTE=false

# HITL
PULSE_JOB_HITL_REQUIRED=true

# 定时巡检 — 打招呼
PULSE_JOB_PATROL_GREET_ENABLED=false
PULSE_JOB_PATROL_GREET_INTERVAL_PEAK=900
PULSE_JOB_PATROL_GREET_INTERVAL_OFFPEAK=1800

# 定时巡检 — 对话
PULSE_JOB_PATROL_CHAT_ENABLED=false
PULSE_JOB_PATROL_CHAT_INTERVAL_PEAK=180
PULSE_JOB_PATROL_CHAT_INTERVAL_OFFPEAK=600


# =========================================================
# [6] BOSS 平台连接器 (由 pulse.modules.job._connectors.boss.settings.BossConnectorSettings 加载)
# =========================================================
# provider 选择: openapi / mcp / web_search;留空自动判别(mcp > openapi > web_search)
PULSE_BOSS_PROVIDER=

# --- OpenAPI 模式 ---
PULSE_BOSS_OPENAPI_BASE_URL=
PULSE_BOSS_OPENAPI_TOKEN=
# Default 45s (upper cap 180s): aligned with MCP tier so fetch_detail bursts
# don't time out at the HTTP client while the upstream is still walking pages.
PULSE_BOSS_OPENAPI_TIMEOUT_SEC=45
PULSE_BOSS_OPENAPI_AUTH_STATUS_PATH=/auth/status
PULSE_BOSS_OPENAPI_SCAN_PATH=/jobs/scan
PULSE_BOSS_OPENAPI_DETAIL_PATH=/jobs/detail
PULSE_BOSS_OPENAPI_GREET_PATH=/jobs/greet
PULSE_BOSS_OPENAPI_PULL_PATH=/chats/pull
PULSE_BOSS_OPENAPI_REPLY_PATH=/chats/reply
PULSE_BOSS_OPENAPI_MARK_PATH=/chats/mark_processed

# --- MCP 模式(浏览器自动化) ---
PULSE_BOSS_MCP_BASE_URL=
PULSE_BOSS_MCP_TOKEN=
# Default 45s (upper cap 180s). `scan_jobs` with fetch_detail=True on ~30 JDs
# routinely takes 25-40s via patchright; 10s caused 3x retry storms while
# the MCP gateway quietly kept running the first request (audit
# trace_f3bda835ed94). Raise to 60-90s if your network + BOSS are slow.
PULSE_BOSS_MCP_TIMEOUT_SEC=45
PULSE_BOSS_MCP_SERVER=boss
PULSE_BOSS_MCP_SCAN_TOOL=scan_jobs
PULSE_BOSS_MCP_DETAIL_TOOL=job_detail
PULSE_BOSS_MCP_GREET_TOOL=greet_job
PULSE_BOSS_MCP_PULL_TOOL=pull_conversations
PULSE_BOSS_MCP_REPLY_TOOL=reply_conversation
PULSE_BOSS_MCP_MARK_TOOL=mark_processed
PULSE_BOSS_MCP_CHECK_LOGIN_TOOL=check_login
PULSE_BOSS_MCP_SEND_ATTACHMENT_TOOL=send_resume_attachment
PULSE_BOSS_MCP_CLICK_CARD_TOOL=click_conversation_card

# --- 可靠性 ---
PULSE_BOSS_RETRY_COUNT=2
PULSE_BOSS_RETRY_BACKOFF_SEC=0.8
PULSE_BOSS_RATE_LIMIT_SEC=1.2
PULSE_BOSS_COOKIE_PATH=
PULSE_BOSS_CONNECTOR_AUDIT_PATH=./data/exports/audit/boss_connector_audit.jsonl
PULSE_BOSS_ALLOW_WEB_SEARCH_FALLBACK=false
PULSE_BOSS_ALLOW_SEED_FALLBACK=false


# =========================================================
# [6.1] BOSS 浏览器运行时(_boss_platform_runtime.py 直接读取)
# 仅在 provider=mcp 时生效。以 MCP Server 进程视角读环境变量。
# =========================================================
PULSE_BOSS_BROWSER_PROFILE_DIR=~/.pulse/boss_browser_profile
PULSE_BOSS_BROWSER_HEADLESS=false
PULSE_BOSS_BROWSER_TIMEOUT_MS=20000
PULSE_BOSS_BROWSER_CHANNEL=
PULSE_BOSS_BROWSER_USER_AGENT=
# 反爬补丁由 patchright 在 Chromium 二进制层处理, 以下两个 env 已弃用,
# 保留名称仅为兼容老 .env 的迁移提示: 设成非空值会在启动时 fail-loud.
# 历史根因 / patchright 决策见 docs/archive/debug-boss-antibot-postmortem.md.
# PULSE_BOSS_BROWSER_STEALTH_ENABLED=
# PULSE_BOSS_BROWSER_BLOCK_IFRAME_CORE=
PULSE_BOSS_LOGIN_CHECK_URL=https://www.zhipin.com/web/geek/chat
PULSE_BOSS_MCP_SCAN_MODE=browser_first
PULSE_BOSS_MCP_PULL_MODE=browser_first
PULSE_BOSS_SEARCH_URL_TEMPLATE=https://www.zhipin.com/web/geek/jobs?query={keyword}
PULSE_BOSS_SCAN_EXTRACT_ATTEMPTS=4
PULSE_BOSS_CHAT_LIST_URL=https://www.zhipin.com/web/geek/chat
PULSE_BOSS_CHAT_URL_TEMPLATE=https://www.zhipin.com/web/geek/chat?conversationId={conversation_id}
PULSE_BOSS_BROWSER_EXECUTOR_RETRY_COUNT=1
PULSE_BOSS_BROWSER_EXECUTOR_RETRY_BACKOFF_MS=700
PULSE_BOSS_RISK_KEYWORDS=验证码,人机验证,访问受限,异常访问,risk,captcha
PULSE_BOSS_MCP_SCREENSHOT_DIR=./data/exports/screenshots
# greet: 默认 browser (真实点"打招呼"按钮). 改成 log_only / dry_run_ok 可用
# 于冒烟不真投. 未知值会 fail-loud 返回 status=mode_not_configured, 不再
# 静默降级为"ok=false + manual_required"(那会让上游把"未尝试"误计入 failed).
PULSE_BOSS_MCP_GREET_MODE=browser
# reply: 回复 HR 风险更高, 默认仍是 manual_required 保守值. 真要自动回复,
# 显式改成 browser.
PULSE_BOSS_MCP_REPLY_MODE=manual_required
# greet 策略 (P3f, trace 2026-04-21 修复):
#   off (默认) = 只点 "立即沟通" 按钮, BOSS 平台自动代发用户在 APP / web 设置里
#                预先配置的打招呼话术. 这也是绝大多数真实 BOSS 账号的实际状态.
#   on         = 点按钮后 Pulse 再 fill + send 一条 greeting_text 作为 followup.
#                仅当你的账号"没设 APP 预设话术"时才启用, 否则 HR 会收到两条重复
#                自我介绍 (图证: 用户 2026-04-21 日聊天截图).
PULSE_BOSS_MCP_GREET_FOLLOWUP=off

# 附件简历(Stage2 新增):本地简历文件路径,供 send_resume_attachment 工具读取
PULSE_BOSS_RESUME_ATTACHMENT_PATH=
# 可选:按 profile_id 映射不同简历文件,格式 "default=/path/a.pdf,long=/path/b.pdf"
PULSE_BOSS_RESUME_ATTACHMENT_MAP=


# =========================================================
# [7] 全局 MCP 注册表
# =========================================================
PULSE_MCP_SERVERS_CONFIG_PATH=config/mcp_servers.yaml
PULSE_MCP_PREFERRED_SERVER=boss


# =========================================================
# [8] 邮件(IMAP)
# =========================================================
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

EMAIL_HEARTBEAT_ENABLED=false
EMAIL_HEARTBEAT_INTERVAL_SEC=1800
EMAIL_HEARTBEAT_MAX_ITEMS=10
EMAIL_HEARTBEAT_MARK_SEEN=false
EMAIL_HEARTBEAT_NOTIFY_ON_UPDATES=true

EMAIL_SCHEDULE_REMINDER_HOURS=24
EMAIL_SCHEDULE_UPCOMING_DAYS=14


# =========================================================
# [9] 通知(飞书 / 其它 Webhook)
# =========================================================
NOTIFY_WEBHOOK_URL=
NOTIFY_MODE=feishu_card
NOTIFY_TIMEOUT_SEC=8


# =========================================================
# [10] 企业微信(WeCom)IM
# =========================================================
WECHAT_WORK_CORP_ID=
WECHAT_WORK_AGENT_ID=
WECHAT_WORK_SECRET=
WECHAT_WORK_TOKEN=
WECHAT_WORK_ENCODING_AES_KEY=
# 智能机器人长连模式
WECHAT_WORK_BOT_ID=
WECHAT_WORK_BOT_SECRET=


# =========================================================
# [11] 公司情报 Web 搜索
# =========================================================
WEB_SEARCH_PROVIDER=auto
WEB_SEARCH_TIMEOUT_SEC=10
WEB_SEARCH_MAX_RESULTS=6
TAVILY_API_KEY=


# =========================================================
# [12] 材料生成与导出
# =========================================================
MATERIAL_MIN_MATCH_SCORE=60
MATERIAL_EXPORT_DIR=./data/exports/materials
